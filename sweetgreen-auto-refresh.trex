<?xml version="1.0" encoding="utf-8"?>
<manifest manifest-version="0.1" xmlns="http://www.tableau.com/xml/extension_manifest">
  <dashboard-extension id="com.sweetgreen.extension.autorefresh" extension-version="1.0.0">
    <default-locale>en_US</default-locale>
    <name resource-id="name"/>
    <description>Custom auto-refresh extension for Sweetgreen dashboards. Refreshes all data sources at a user-defined interval (default: 60 seconds). No upper-limit restriction.</description>
    <author name="Sweetgreen Data" email="harikrishnan.radhakrishnan.ext@sweetgreen.com" organization="Sweetgreen" website="https://www.sweetgreen.com"/>
    <min-api-version>1.0</min-api-version>
    <source-location>
      <!--
        STEP 1 (Local testing in Tableau Desktop):
          Replace the URL below with: http://localhost:8080/index.html
          Then run: python -m http.server 8080
          from inside the auto-refresh-extension/ folder.

        STEP 2 (Tableau Online / 10ay.online.tableau.com):
          Replace the URL below with your GitHub Pages URL, e.g.:
          https://<your-github-username>.github.io/sg-auto-refresh/index.html
          Must be HTTPS for Tableau Online.
      -->
      <url>https://hkrrkn.github.io/sg-auto-refresh/index.html</url>
    </source-location>
    <icon></icon>
<permissions>
      <permission>full data</permission>
    </permissions>
    <context-menu>
      <configure-context-menu-item />
    </context-menu>
  </dashboard-extension>
  <resources>
    <resource id="name">
      <text locale="en_US">Sweetgreen Auto Refresh</text>
    </resource>
  </resources>
</manifest>
